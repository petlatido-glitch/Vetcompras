generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum CategoriaProducto {
  MEDICAMENTOS
  ANTIPARASITARIO
  ALIMENTO
  INSUMO_MEDICO
  HOSPITALARIO
  VACUNAS
  JUGUETES
  ACCESORIOS
  OTRO
  CONCENTRADOS
  INSUMOS
}

enum EstadoProducto {
  ACTIVO
  INACTIVO
}

enum CategoriaProveedor {
  MEDICAMENTOS
  CONCENTRADOS
  LABORATORIO
  ACCESORIOS
  VACUNAS
  VARIOS
}

enum EstadoProveedor {
  ACTIVO
  INACTIVO
}

enum EstadoCompra {
  BORRADOR
  GENERADA
  ENVIADA
  RECIBIDA
  CANCELADA
}

model Producto {
  id              String            @id @default(uuid())
  nombre          String
  categoria       CategoriaProducto
  marca           String?
  laboratorio     String?
  proveedorId     String?            @map("proveedor_id")
  proveedor       Proveedor?         @relation(fields: [proveedorId], references: [id], onDelete: Cascade)
  sku             String?
  unidad          String
  stockActual     Int               @map("stock_actual")
  stockMinimo     Int               @map("stock_minimo")
  precioCompra    Decimal?          @map("precio_compra") @db.Decimal(12, 2)
  precioSugerido  Decimal?          @map("precio_sugerido") @db.Decimal(12, 2)
  ultimoCosto     Decimal?          @map("ultimo_costo") @db.Decimal(12, 2)
  presentacion    String?
  lote            String?
  fechaVencimiento DateTime?       @map("fecha_vencimiento")
  observaciones   String?          @db.Text
  estado          EstadoProducto    @default(ACTIVO)
  createdAt       DateTime          @default(now()) @map("created_at")
  cotizacionItems CotizacionItem[]
  listaCompra     ListaCompraItem[]
  historiales     HistorialPrecio[]
  ordenItems      OrdenCompraItem[]
  movimientos     MovimientoInventario[]
  alertas         AlertaInventario[]

  @@index([proveedorId])
  @@map("productos")
}

model Proveedor {
  id              String            @id @default(uuid())
  nombre          String
  contacto        String?
  telefono        String?
  whatsapp        String?
  email           String?
  ciudad          String?
  direccion       String?
  categoria       CategoriaProveedor @default(VARIOS)
  estado          EstadoProveedor    @default(ACTIVO)
  notas           String?
  createdAt       DateTime          @default(now()) @map("created_at")
  cotizaciones    Cotizacion[]
  historiales     HistorialPrecio[]
  ordenesCompra   OrdenCompra[]
  productos       Producto[]

  @@map("proveedores")
}

model Cotizacion {
  id              String            @id @default(uuid())
  proveedorId     String            @map("proveedor_id")
  fecha           DateTime
  archivoUrl      String            @map("archivo_url")
  archivoNombre   String            @map("archivo_nombre")
  archivoTipo     String            @map("archivo_tipo")
  estadoOcr       String            @default("pendiente") @map("estado_ocr")
  createdAt       DateTime          @default(now()) @map("created_at")
  proveedor       Proveedor         @relation(fields: [proveedorId], references: [id], onDelete: Cascade)
  items           CotizacionItem[]

  @@index([proveedorId])
  @@map("cotizaciones")
}

model CotizacionItem {
  id              String      @id @default(uuid())
  cotizacionId    String      @map("cotizacion_id")
  productoId      String?     @map("producto_id")
  nombreDetectado String      @map("nombre_detectado")
  nombreOcr       String?     @map("nombre_ocr")
  nombreGenerico  String?     @map("nombre_generico")
  laboratorio     String?
  cantidad        Int?
  cantidadUnidad  String?     @map("cantidad_unidad")
  precio          Decimal     @db.Decimal(12, 2)
  precioUnitario  Decimal?    @map("precio_unitario") @db.Decimal(12, 2)
  precioTotal     Decimal?    @map("precio_total") @db.Decimal(12, 2)
  presentacion    String?
  cotizacion      Cotizacion  @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  producto        Producto?   @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@index([cotizacionId])
  @@index([productoId])
  @@map("cotizacion_items")
}

model ListaCompraItem {
  id               String   @id @default(uuid())
  productoId       String   @map("producto_id")
  cantidadRequerida Int     @map("cantidad_requerida")
  estado           EstadoListaCompra @default(PENDIENTE)
  notas            String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  producto         Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@unique([productoId])
  @@map("lista_compra_items")
}

enum EstadoListaCompra {
  PENDIENTE
  COTIZADO
  COMPRADO
  RECIBIDO
}

model Compra {
  id             String         @id @default(uuid())
  fecha          DateTime       @default(now())
  ahorroEstimado Decimal        @default(0) @map("ahorro_estimado") @db.Decimal(12, 2)
  estado         EstadoCompra   @default(BORRADOR)
  ordenesCompra  OrdenCompra[]

  @@map("compras")
}

model OrdenCompra {
  id               String            @id @default(uuid())
  compraId         String            @map("compra_id")
  proveedorId      String            @map("proveedor_id")
  pdfUrl           String?           @map("pdf_url")
  mensajeWhatsapp  String            @map("mensaje_whatsapp")
  createdAt        DateTime          @default(now()) @map("created_at")
  compra           Compra            @relation(fields: [compraId], references: [id], onDelete: Cascade)
  proveedor        Proveedor         @relation(fields: [proveedorId], references: [id], onDelete: Cascade)
  items            OrdenCompraItem[]

  @@index([compraId])
  @@index([proveedorId])
  @@map("ordenes_compra")
}

model OrdenCompraItem {
  id              String      @id @default(uuid())
  ordenCompraId   String      @map("orden_compra_id")
  productoId      String      @map("producto_id")
  cantidad        Int
  precioUnitario  Decimal     @map("precio_unitario") @db.Decimal(12, 2)
  ordenCompra     OrdenCompra @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
  producto        Producto    @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@index([ordenCompraId])
  @@index([productoId])
  @@map("orden_compra_items")
}

model HistorialPrecio {
  id          String    @id @default(uuid())
  productoId  String    @map("producto_id")
  proveedorId String    @map("proveedor_id")
  fecha       DateTime
  precio      Decimal   @db.Decimal(12, 2)
  producto    Producto  @relation(fields: [productoId], references: [id], onDelete: Cascade)
  proveedor   Proveedor @relation(fields: [proveedorId], references: [id], onDelete: Cascade)

  @@index([productoId, fecha])
  @@index([proveedorId])
  @@map("historial_precios")
}

enum TipoMovimientoInventario {
  ENTRADA
  SALIDA
  AJUSTE
  COMPRA
  USO_CLINICO
  MERMA
}

model MovimientoInventario {
  id              String    @id @default(uuid())
  productoId      String    @map("producto_id")
  tipo            TipoMovimientoInventario
  cantidad        Int
  cantidadAntes   Int       @map("cantidad_antes")
  cantidadDespues Int       @map("cantidad_despues")
  motivo          String?   @db.Text
  usuario         String?
  fecha           DateTime  @default(now())
  createdAt       DateTime  @default(now()) @map("created_at")
  
  producto        Producto  @relation(fields: [productoId], references: [id], onDelete: Cascade)
  
  @@index([productoId, fecha])
  @@map("movimientos_inventario")
}

model AlertaInventario {
  id          String    @id @default(uuid())
  productoId  String    @map("producto_id")
  tipo        String
  estado      String    @default("ACTIVA")
  fecha       DateTime  @default(now())
  
  producto    Producto  @relation(fields: [productoId], references: [id], onDelete: Cascade)
  
  @@index([productoId, estado])
  @@map("alertas_inventario")
}
